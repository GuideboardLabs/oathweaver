{
  "llama_cpp_servers": {
    "turbo_deepseek": {
      "base_url": "http://127.0.0.1:8180",
      "models": [
        "qwen3:8b",
        "deepseek-r1:8b",
        "qwen2.5-coder:7b"
      ],
      "fallback_to_ollama": true
    }
  },

  "premium_models": [
    "mistral-small3.1:24b",
    "phi4:14b",
    "qwen3-coder:30b-a3b-q4_K_M",
    "qwen3:30b-a3b-q4_K_M"
  ],

  "reynard_layer": {
    "purpose": "User-facing messenger layer above the internal orchestrator",
    "provider": "ollama",
    "model": "qwen3:8b",
    "temperature": 0.6,
    "num_ctx": 8192,
    "timeout_sec": 180,
    "retry_attempts": 3,
    "retry_backoff_sec": 1.2,
    "fallback_models": [
      "phi4-mini:3.8b",
      "deepseek-r1:8b"
    ]
  },

  "conversation_layer": {
    "purpose": "Legacy direct conversational fallback",
    "provider": "ollama",
    "model": "qwen3:8b",
    "temperature": 0.55,
    "num_ctx": 8192,
    "timeout_sec": 180,
    "retry_attempts": 3,
    "retry_backoff_sec": 1.2,
    "fallback_models": [
      "phi4-mini:3.8b",
      "deepseek-r1:8b"
    ]
  },

  "orchestrator_reasoning": {
    "purpose": "Internal task planning, routing, and execution synthesis",
    "provider": "ollama",
    "model": "qwen3:8b",
    "temperature": 0.15,
    "num_ctx": 12288,
    "think": true,
    "timeout_sec": 150,
    "retry_attempts": 3,
    "retry_backoff_sec": 2.0,
    "fallback_models": [
      "deepseek-r1:8b",
      "qwen2.5-coder:7b"
    ],

    "synthesis_timeout_sec": 240,
    "synthesis_retry_attempts": 4,
    "synthesis_retry_backoff_sec": 2.0,
    "synthesis_validation_cycles": 2,
    "synthesis_fallback_models": [
      "mistral-small3.1:24b",
      "deepseek-r1:8b"
    ],

    "reflection_gate_open_limit": 2,
    "reflection_temperature": 0.15,
    "reflection_num_ctx": 12288,
    "reflection_think": true,
    "reflection_timeout_sec": 240
  },

  "research_pool": {
    "purpose": "Foraging and evidence synthesis — reading web crawl output and general reasoning",
    "provider": "ollama",
    "model": "qwen3:8b",
    "parallel_agents": 2,
    "temperature": 0.3,
    "num_ctx": 12288,
    "timeout_sec": 360,
    "retry_attempts": 3,
    "retry_backoff_sec": 2.0,
    "validation_cycles": 2,
    "gap_fill_enabled": false,

    "draft_critique_revise": {
      "enabled": true,
      "critic_lane": "synthesis",
      "max_revise_loops": 2
    },

    "fallback_models": [
      "deepseek-r1:8b",
      "qwen2.5-coder:7b"
    ],

    "agent_mix": [
      {
        "persona": "market_analyst",
        "model": "qwen3:8b",
        "directive": "Focus on market dynamics, alternatives, and strategic positioning. Read between the lines of sources.",
        "num_ctx": 12288,
        "retry_attempts": 6,
        "retry_backoff_sec": 2.0,
        "fallback_models": [
          "deepseek-r1:8b",
          "qwen2.5-coder:7b"
        ],
        "validation_cycles": 2
      },

      {
        "persona": "technical_researcher",
        "model": "deepseek-r1:8b",
        "think": true,
        "num_ctx": 16384,
        "directive": "Focus on technical feasibility, architecture tradeoffs, math, science, and engineering bottlenecks.",
        "validation_cycles": 2
      },

      {
        "persona": "risk_researcher",
        "model": "deepseek-r1:8b",
        "think": true,
        "num_ctx": 16384,
        "directive": "Focus on risks, failure modes, constraints, and mitigation plans.",
        "validation_cycles": 2
      },

      {
        "persona": "execution_planner",
        "model": "qwen3:8b",
        "directive": "Focus on practical sequencing, milestones, and resource-fit execution.",
        "validation_cycles": 2
      }
    ]
  },

  "synthesis": {
    "purpose": "Cross-agent synthesis — unified narrative output",
    "provider": "ollama",

    "model": "qwen3:8b",
    "temperature": 0.2,
    "num_ctx": 12288,
    "timeout_sec": 420,

    "synthesis_retry_attempts": 3,
    "synthesis_validation_cycles": 2,
    "synthesis_retry_backoff_sec": 2.0,

    "synthesis_fallback_models": [
      "deepseek-r1:8b",
      "qwen2.5-coder:7b"
    ],

    "tier_default": {
      "model": "qwen3:8b",
      "num_ctx": 12288,
      "temperature": 0.2,
      "timeout_sec": 420,
      "retry_attempts": 3,
      "retry_backoff_sec": 2.0,
      "fallback_models": [
        "deepseek-r1:8b",
        "qwen2.5-coder:7b"
      ]
    },

    "tier_premium": {
      "model": "mistral-small3.1:24b",
      "num_ctx": 32768,
      "temperature": 0.2,
      "num_gpu": 24,
      "keep_alive": "0",
      "timeout_sec": 900,
      "retry_attempts": 2,
      "retry_backoff_sec": 2.0,

      "fallback_models": [
        "qwen3:30b-a3b-q4_K_M",
        "phi4:14b"
      ],

      "synthesis_retry_attempts": 2,
      "synthesis_retry_backoff_sec": 2.0,
      "synthesis_validation_cycles": 2
    },

    "escalation_policy": {
      "enabled": true,
      "importance_min": "high",
      "severity_min": 3,
      "max_premium_passes": 1,
      "max_revise_loops": 2,
      "require_prior_default_pass": true,
      "cooloff_sec": 60
    }
  },

  "make_longform": {
    "purpose": "Long-form essays, scripts, guides, tutorials, newsletters",
    "provider": "ollama",

    "model": "mistral-small3.1:24b",
    "temperature": 0.55,
    "num_ctx": 32768,
    "timeout_sec": 600,
    "retry_attempts": 4,
    "retry_backoff_sec": 2.0,
    "num_gpu": 24,

    "fallback_models": [
      "qwen3:30b-a3b-q4_K_M",
      "qwen3:8b"
    ],

    "tier_premium": {
      "model": "qwen3:30b-a3b-q4_K_M",
      "num_ctx": 24576,
      "num_gpu": 28,
      "keep_alive": "0",
      "timeout_sec": 900,
      "retry_attempts": 2,
      "retry_backoff_sec": 2.0
    },

    "escalation_policy": {
      "enabled": true,
      "importance_min": "high",
      "severity_min": 3,
      "max_premium_passes": 1,
      "max_revise_loops": 1
    }
  },

